# ============================================================
# Project Zankar — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------ Google Gemini API (Required for Stage 2 log parsing) ------
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ------ Local Fallback Model (Optional) ------
# Path to a local model used when Gemini API is unavailable.
# Supports: MLX-format models, .gguf files, or LM Studio server.
# Examples:
#   GEMMA_MODEL_PATH=~/Downloads/AI_Models/gemma-3-4b-it-4bit
#   GEMMA_MODEL_PATH=/path/to/model.gguf
GEMMA_MODEL_PATH=

# ------ Whisper Model (Set inside live_transcribe.py) ------
# The Whisper model path is configured directly in live_transcribe.py (line 215).
# Download a model first:  python3 download_model.py
# Example path: ~/Downloads/AI_Models/whisper-large-v3-turbo
